style.name: archlinux2
style.author: wickedlester 
style.date: 05.14.06 
style.credits: made to represent my linux distro
style.comments: thanks to the *box community and archlinux


#rootCommand: fbsetbg -f ~/.blackbox/backgrounds/arch_simple.png
#rootCommand: fbsetbg -b -gradient elliptic -from rgb:4c/54/58 -to rgb:37/3e/41

#*font: snap-8
#*font: Noto Sans Regular-9
*font: JetBrains Mono Medium-10
#*font: Roboto-Regular

borderWidth: 1
marginWidth: 3
menu.marginWidth: 3

toolbar.alignment: center
menu.title.alignment: center
menu.frame.alignment: left
window.alignment: center
window.frame.borderWidth: 1

#== toolbar
toolbar.appearance: raised gradient vertical border
toolbar.color1: #4c5458
toolbar.color2: #373e41
toolbar.borderColor: #000000
#toolbar.font: Roboto-10
#toolbar.font: JetBrains Mono Medium-10

toolbar.label.appearance: sunken gradient vertical border
toolbar.label.color1: #4e81a9
toolbar.label.color2: #759fbf
toolbar.label.textColor: #000000
toolbar.label.marginWidth: 1

toolbar.clock.appearance: sunken gradient vertical border
toolbar.clock.color1: #4e81a9
toolbar.clock.color2: #759fbf
toolbar.clock.textColor: #000000

toolbar.windowLabel.appearance: sunken gradient vertical border
toolbar.windowLabel.Color1: #4e81a9
toolbar.windowLabel.Color2: #759fbf
toolbar.windowLabel.textColor: #000000

toolbar.button.appearance: raised gradient vertical border
toolbar.button.color1: #4c5458
toolbar.button.color2: #373e41
toolbar.button.foregroundColor: #ffffff

toolbar.button.pressed.appearance: sunken gradient vertical border
toolbar.button.pressed.color1: #4e81a9
toolbar.button.pressed.color2: #759fbf
toolbar.button.pressed.foregroundColor: #000000

#== menu
menu.title.appearance: raised gradient vertical border
menu.title.color1: #4c5458
menu.title.color2: #373e41
menu.title.textColor: #ffffff
menu.title.borderColor: #000000
menu.title.font:	snap-8
menu.title.marginWidth: 2

menu.frame.appearance: raised gradient elliptic border
menu.frame.color1: #4e81a9
menu.frame.color2: #759fbf
menu.frame.textColor: #000000
menu.frame.foregroundColor: #000000
menu.frame.marginWidth: 3

menu.active.appearance: sunken gradient elliptic border
menu.active.color1: #4c5458
menu.active.color2: #373e41
menu.active.foregroundColor: #ffffff
menu.active.textColor: #ffffff
menu.active.borderColor: #000000

#== window
window.title.focus.appearance: raised gradient vertical border
window.title.focus.color1: #4c5458
window.title.focus.color2: #373e41
window.title.focus.borderColor: #000000

window.title.unfocus.appearance: raised gradient vertical border
window.title.unfocus.color1: #4c5458
window.title.unfocus.color2: #373e41
window.title.unfocus.borderColor: #000000

window.label.focus.appearance: sunken gradient vertical border
window.label.focus.Color1: #4e81a9
window.label.focus.Color2: #759fbf
window.label.focus.textColor: #000000
window.label.marginWidth: 1
window.label.unfocus.appearance: parentrelative
window.label.unfocus.textColor: #000000

window.button.focus.appearance: raised gradient vertical border
window.button.focus.color1: #4c5458
window.button.focus.color2: #373e41
window.button.focus.foregroundColor: #ffffff
window.button.unfocus.appearance: parentrelative
window.button.unfocus.foregroundColor: #000000

window.handle.focus.appearance: raised gradient vertical border
window.handle.focus.color1: #4c5458
window.handle.focus.color2: #373e41
window.handle.focus.borderColor: #000000
window.handle.unfocus.appearance: flat solid border
window.handle.unfocus.color: #4c5458
window.handle.unfocus.borderColor: #000000
window.handleHeight: 3

window.grip.focus.appearance: raised solid border
window.grip.focus.color: #4e81a9
window.grip.focus.borderColor: #000000
window.grip.unfocus.appearance: flat solid border
window.grip.unfocus.color: #4e81a9
window.grip.unfocus.borderColor: #000000

window.frame.focus.borderColor: #000000
window.frame.unfocus.borderColor: #000000

#== slit
#uncomment for dark colored slit
#slit.appearance: raised gradient vertical border
#slit.color1: #4c5458
#slit.color2: #373e41
#slit.borderColor: #000000
#slit.borderwidth: 1

#comment this out for dark colored slit
slit.appearance: raised gradient elliptic border
slit.color1: #4e81a9
slit.color2: #759fbf
slit.borderColor: #000000
slit.borderwidth: 1
