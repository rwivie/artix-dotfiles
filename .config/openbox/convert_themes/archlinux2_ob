style.name: archlinux2
style.author: wickedlester
style.date: 05.14.06
style.credits: made to represent my linux distro
style.comments: thanks to the *box community and archlinux


#rootCommand: fbsetbg -f ~/.blackbox/backgrounds/arch_simple.png
#rootCommand: fbsetbg -b -gradient elliptic -from rgb:4c/54/58 -to rgb:37/3e/41

#*font: snap-8
#*font: Noto Sans Regular-9
*font: JetBrains Mono Medium-10
#*font: Roboto-Regular

border.width: 1
marginWidth: 3
menu.marginWidth: 3

menu.title.alignment: center
menu.items.alignment: left
window.alignment: center
window.frame.borderWidth: 1

#== toolbar






#== menu
menu.title.appearance: raised gradient vertical border
menu.title.bg.color1: #4c5458
menu.title.bg.color2: #373e41
menu.title.text.color: #ffffff
menu.title.bg.border.color: #000000
menu.title.text.font:	snap-8
menu.title.marginWidth: 2

menu.items.appearance: raised gradient elliptic border
menu.items.bg.color1: #4e81a9
menu.items.bg.color2: #759fbf
menu.items.text.color: #000000
menu.items.foregroundColor: #000000
menu.items.marginWidth: 3

menu.active.appearance: sunken gradient elliptic border
menu.active.bg.color1: #4c5458
menu.active.bg.color2: #373e41
menu.active.foregroundColor: #ffffff
menu.active.text.color: #ffffff
menu.active.bg.border.color: #000000

#== window
window.active.title.appearance: raised gradient vertical border
window.active.title.bg.color1: #4c5458
window.active.title.bg.color2: #373e41
window.active.title.bg.border.color: #000000

window.inactive.title.appearance: raised gradient vertical border
window.inactive.title.bg.color1: #4c5458
window.inactive.title.bg.color2: #373e41
window.inactive.title.bg.border.color: #000000

window.active.label.appearance: sunken gradient vertical border
window.active.label.Color1: #4e81a9
window.active.label.Color2: #759fbf
window.active.label.text.color: #000000
window.label.marginWidth: 1
window.inactive.label.appearance: parentrelative
window.inactive.label.text.color: #000000

window.active.button.unpressed.appearance: raised gradient vertical border
window.active.button.unpressed.bg.color1: #4c5458
window.active.button.unpressed.bg.color2: #373e41
window.active.button.unpressed.foregroundColor: #ffffff
window.inactive.button.unpressed.appearance: parentrelative
window.inactive.button.unpressed.foregroundColor: #000000

window.active.handle.appearance: raised gradient vertical border
window.active.handle.bg.color1: #4c5458
window.active.handle.bg.color2: #373e41
window.active.handle.bg.border.color: #000000
window.inactive.handle.appearance: flat solid border
window.inactive.handle.bg.color: #4c5458
window.inactive.handle.bg.border.color: #000000
window.handleHeight: 3

window.active.grip.appearance: raised solid border
window.active.grip.bg.color: #4e81a9
window.active.grip.bg.border.color: #000000
window.inactive.grip.appearance: flat solid border
window.inactive.grip.bg.color: #4e81a9
window.inactive.grip.bg.border.color: #000000

window.frame.focus.bg.border.color: #000000
window.frame.unfocus.bg.border.color: #000000

#== slit
#uncomment for dark colored slit
#slit.appearance: raised gradient vertical border
#slit.bg.color1: #4c5458
#slit.bg.color2: #373e41
#slit.bg.border.color: #000000
#slit.borderwidth: 1

#comment this out for dark colored slit
slit.appearance: raised gradient elliptic border
slit.bg.color1: #4e81a9
slit.bg.color2: #759fbf
slit.bg.border.color: #000000
slit.borderwidth: 1
